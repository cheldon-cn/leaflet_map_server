<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>

<VBox fx:id="root" xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1" 
      spacing="8" style="-fx-padding: 8;">
    
    <HBox spacing="4" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="搜索数据..." HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshButton" text="刷新"/>
    </HBox>
    
    <TreeView fx:id="dataTree" VBox.vgrow="ALWAYS"/>
    
</VBox>
