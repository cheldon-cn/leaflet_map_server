  <LookupStructure>
    <Description>
      CARIS S-57 符号化查询表定义了 ENC 物标到 S-52 符号的映射关系。
      支持 IHO S-57 和 S-100 系列标准，提供验证和表示工具。
    </Description>
    <Fields>
      <Field name="OBJL" description="物标标签/物标代码"/>
      <Field name="RCID" description="记录标识符"/>
      <Field name="PRIM" description="图元类型：1=点, 2=线, 3=面"/>
      <Field name="GRUP" description="显示组"/>
      <Field name="OBJNAM" description="物标名称"/>
      <Field name="DPRI" description="显示优先级"/>
      <Field name="RADR" description="雷达相关性"/>
      <Field name="NOBJNAM" description="导航物标名称"/>
      <Field name="NINF" description="导航信息"/>
      <Field name="SORD" description="显示顺序"/>
    </Fields>
  </LookupStructure>
  
