<?xml version="1.0" encoding="UTF-8"?>
<SuperMapLookupTable name="psymref_paperchart" type="POINT_COMPLEX" description="复杂点符号显示命令" standard="SuperMap iMaritimeEditor S-52">
  <MetaData>
    <Source>bin/Resource/Chart/Presentation/S52/LookupTable/psymref_paperchart.dic</Source>
    <Software>SuperMap iMaritimeEditor</Software>
    <CreateDate>2026-05-05</CreateDate>
    <Format>物标缩写,属性条件,符号指令,优先级,雷达,显示类别,视图分组</Format>
    <Reference>https://help.supermap.com/iMaritimeEditor/zh/tutorial/Chart/Visualization/ObjectextensionRule.html</Reference>
  </MetaData>
  
  <CommandFormat>
    <Field index="1" name="ObjectClass" description="物标缩写，如BOYCAR、LIGHTS"/>
    <Field index="2" name="Condition" description="属性条件，格式为属性字段+值，如PRODCT3表示PRODCT=3"/>
    <Field index="3" name="Symbol" description="符号指令，如SY(BOYCAR01)、LC(PIPSOL06)"/>
    <Field index="4" name="Priority" description="显示优先级(1-9)，数值越大越后绘制"/>
    <Field index="5" name="Radar" description="是否跟雷达相关，目前都是O"/>
    <Field index="6" name="DisplayCategory" description="显示类别：Base/Standard/OTHER"/>
    <Field index="7" name="ViewingGroup" description="视图分组，逻辑分组不影响显示效果"/>
  </CommandFormat>
  
  <SymbolInstructions>
    <Instruction name="SY" syntax="SY(符号名)" description="点符号">
      <Example>SY(BOYCAR01)</Example>
    </Instruction>
    <Instruction name="LS" syntax="LS(线型,线宽,颜色)" description="线型渲染">
      <Example>LS(SOLD,3,CHGRD)</Example>
      <LineStyles>
        <Style name="SOLD" description="实线"/>
        <Style name="DASH" description="虚线"/>
        <Style name="DOT" description="点线"/>
      </LineStyles>
    </Instruction>
    <Instruction name="LC" syntax="LC(线符号名)" description="线符号">
      <Example>LC(PIPSOL06)</Example>
    </Instruction>
    <Instruction name="AP" syntax="AP(面符号名)" description="面填充图案">
      <Example>AP(DIAMOND01)</Example>
    </Instruction>
    <Instruction name="AC" syntax="AC(颜色名称)" description="面填充色">
      <Example>AC(LANDF)</Example>
    </Instruction>
    <Instruction name="TE" syntax="TE('格式',字段,水平对齐,垂直对齐,间隔,视图组,X偏移,Y偏移,颜色,优先级)" description="文本标签">
      <Example>TE('bn%s','OBJNAM',2,1,2,'15110',-1,-1,CHBLK,21)</Example>
    </Instruction>
    <Instruction name="TX" syntax="TX(...)" description="文本显示，规则与TE类似"/>
    <Instruction name="CS" syntax="CS(符号名)" description="内部符号命令，不可自定义修改"/>
  </SymbolInstructions>
  
