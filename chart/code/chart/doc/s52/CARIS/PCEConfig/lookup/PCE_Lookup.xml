<?xml version="1.0" encoding="UTF-8"?>
<CARISLookupTable name="PCE_PAPER_CHART" type="PAPER_CHART" description="CARIS Paper Chart Editor 纸质海图查询表" standard="CARIS HPD/PCE S-52">
  <MetaData>
    <Source>C:\Program Files\CARIS\HPD\[version]\system\PCEConfig\lookup\</Source>
    <Software>CARIS HPD Paper Chart Editor (PCE)</Software>
    <CreateDate>2026-05-05</CreateDate>
    <Standard>IHO S-4, INT1, INT2, INT3</Standard>
    <Reference>https://www.teledynecaris.com/en/products/hpd/</Reference>
  </MetaData>
  
  <LookupStructure>
    <Description>
      CARIS Paper Chart Editor (PCE) 用于编译和发布纸质海图产品。
      支持从 HPD 数据库创建矢量或栅格格式的纸质海图。
      查询表定义了纸质海图的符号化规则和显示指令。
    </Description>
    <Features>
      <Feature>符合 IHO S-4, INT1, INT2, INT3 标准的制图表示</Feature>
      <Feature>支持自定义海图配置</Feature>
      <Feature>与 ENC 产品共享同一数据源，确保一致性</Feature>
    </Features>
  </LookupStructure>
  
