  <SymbolNamingConvention>
    <Rule pattern="[PREFIX][TYPE][NUMBER]">
      <Example>BOYCAR01 = BOY(浮标) + CAR(方位标) + 01(序号)</Example>
      <Example>BCNLAT02 = BCN(信标) + LAT(侧面标) + 02(序号)</Example>
      <Example>LIGHTS05 = LIGHTS(灯塔) + 05(序号)</Example>
      <Example>CHRVDEL1 = CHRV(海图修订) + DEL(删除) + 1(点类型)-Ed4.0新增</Example>
      <Example>CHRVID02 = CHRV(海图修订) + ID(插入/删除) + 02(线/面类型)-Ed4.0新增</Example>
      <Example>DNGHLK01 = DNG(危险) + HLK(高亮) + 01(类型)-Ed4.0新增</Example>
    </Rule>
  </SymbolNamingConvention>
  
  <SymbolRenderingRules>
    <Rule name="SY" description="点符号渲染">
      <Syntax>SY(symbol_name)</Syntax>
      <Example>SY(BOYCAR01)</Example>
    </Rule>
    <Rule name="LS" description="线型渲染">
      <Syntax>LS(line_style, width, color_token)</Syntax>
      <Example>LS(SOLD,2,CHBLK)</Example>
      <LineStyles>
        <Style name="SOLD" description="实线"/>
        <Style name="DASH" description="虚线"/>
        <Style name="DOT" description="点线"/>
        <Style name="DASHDOT" description="点划线"/>
      </LineStyles>
    </Rule>
    <Rule name="LC" description="线符号渲染">
      <Syntax>LC(line_symbol_name)</Syntax>
      <Example>LC(PIPSOL01)</Example>
    </Rule>
    <Rule name="AC" description="面填充色">
      <Syntax>AC(color_token)</Syntax>
      <Example>AC(LANDF)</Example>
    </Rule>
    <Rule name="AP" description="面填充图案">
      <Syntax>AP(pattern_name)</Syntax>
      <Example>AP(DIAMOND01)</Example>
    </Rule>
    <Rule name="TE" description="文本标签">
      <Syntax>TE('format', field_name, h_align, v_align, spacing, viewing_group, x_offset, y_offset, color, priority)</Syntax>
      <Example>TE('bn%s','OBJNAM',2,1,2,'15110',-1,-1,CHBLK,21)</Example>
    </Rule>
    <Rule name="TX" description="文本显示">
      <Syntax>TX('format', field_name, h_align, v_align, spacing, viewing_group, x_offset, y_offset, color, priority)</Syntax>
      <Example>TX('%s','OBJNAM',2,1,2,'15110',-1,-1,CHBLK,21)</Example>
    </Rule>
    <Rule name="CS" description="条件符号化">
      <Syntax>CS(symbol_procedure)</Syntax>
      <Note>内部符号命令，不可自定义修改</Note>
    </Rule>
  </SymbolRenderingRules>
</S52SymbolLibrary>
