<?xml version="1.0" encoding="UTF-8"?>
<SuperMapLookupTable name="asymref_symbolized" type="AREA_SYMBOLIZED" description="符号化边界面符号显示命令" standard="SuperMap iMaritimeEditor S-52">
  <MetaData>
    <Source>bin/Resource/Chart/Presentation/S52/LookupTable/asymref_symbolized.dic</Source>
    <Software>SuperMap iMaritimeEditor</Software>
    <CreateDate>2026-05-05</CreateDate>
    <Format>物标缩写,属性条件,符号指令,优先级,雷达,显示类别,视图分组</Format>
    <Reference>https://help.supermap.com/iMaritimeEditor/zh/tutorial/Chart/Visualization/ObjectextensionRule.html</Reference>
  </MetaData>
  
  <CommandFormat>
    <Field index="1" name="ObjectClass" description="物标缩写"/>
    <Field index="2" name="Condition" description="属性条件"/>
    <Field index="3" name="Symbol" description="符号指令，可包含多个指令用分号分隔"/>
    <Field index="4" name="Priority" description="显示优先级"/>
    <Field index="5" name="Radar" description="雷达相关"/>
    <Field index="6" name="DisplayCategory" description="显示类别"/>
    <Field index="7" name="ViewingGroup" description="视图分组"/>
  </CommandFormat>
  
  <AreaInstructions>
    <Instruction name="AC" syntax="AC(颜色名称)" description="面填充色">
      <Example>AC(LANDF)</Example>
    </Instruction>
    <Instruction name="AP" syntax="AP(面符号名)" description="面填充图案">
      <Example>AP(DIAMOND01)</Example>
    </Instruction>
    <Instruction name="LS" syntax="LS(线型,线宽,颜色)" description="边界线型">
      <Example>LS(SOLD,1,CHBLK)</Example>
    </Instruction>
    <Instruction name="SY" syntax="SY(符号名)" description="面内点符号">
      <Example>SY(ACHARE01)</Example>
    </Instruction>
    <Instruction name="TE" syntax="TE(...)" description="文本标签"/>
  </AreaInstructions>
  
