# Application
APP_NAME=project-name
APP_ENV=development
APP_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=project_db
DB_USER=postgres
DB_PASSWORD=changeme

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE=logs/app.log

# Native Library
NATIVE_LIBRARY_PATH=./lib
NATIVE_DEBUG=false

# Security
JWT_SECRET=your-secret-key-change-me
JWT_EXPIRATION=86400000

# Cache
CACHE_TYPE=redis
CACHE_HOST=localhost
CACHE_PORT=6379

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
