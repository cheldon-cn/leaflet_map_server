# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/migration_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=20

# MinIO配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET=migration-files

# JWT配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 应用配置
API_V1_STR=/api/v1
PROJECT_NAME=ArcGIS Pro迁移工具
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
HOST=0.0.0.0
PORT=8000
RELOAD=True
LOG_LEVEL=INFO
DOCS_ENABLED=True
ENVIRONMENT=development
DEBUG=True

# 文件上传配置
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=[".aprx", ".zip", ".qgs", ".gpkg"]
UPLOAD_DIR=./uploads

# 迁移工具配置
MIGRATION_SCRIPT_PATH=../../script
MIGRATION_TIMEOUT=3600
MIGRATION_WORKERS=4