# ArcGIS Pro到QGIS迁移工具环境变量示例
# 复制此文件为.env并修改实际值

# ========================================
# 数据库配置
# ========================================

# 源数据库（ArcGIS Pro数据源）
PGHOST_SOURCE=source.db.example.com
PGPORT_SOURCE=5432
PGDATABASE_SOURCE=source_gis
PGUSER_SOURCE=source_user
# 密码建议通过PGPASSWORD_SOURCE环境变量设置，不要直接写在此文件

# 目标数据库（QGIS数据源）
PGHOST_TARGET=target.db.example.com
PGPORT_TARGET=5432
PGDATABASE_TARGET=target_gis
PGUSER_TARGET=target_user
# 密码建议通过PGPASSWORD_TARGET环境变量设置

# 通用数据库配置（如未设置源/目标特定配置，则使用此配置）
PGHOST=localhost
PGPORT=5432
PGDATABASE=migration_db
PGUSER=migration_user
PGPASSWORD=your_secure_password_here

# ========================================
# 路径配置
# ========================================

# 工作目录
WORK_DIR=/opt/migration_tool

# 输入目录（存放.aprx文件）
INPUT_DIR=/data/input

# 输出目录（存放迁移结果）
OUTPUT_DIR=/data/output

# 临时目录
TEMP_DIR=/tmp/migration

# ========================================
# 性能配置
# ========================================

# 批量处理大小
BATCH_SIZE=10000

# 最大工作线程数
MAX_WORKERS=4

# 任务超时时间（秒）
TIMEOUT_SECONDS=3600

# 内存限制（MB）
MEMORY_LIMIT_MB=4096

# ========================================
# 日志配置
# ========================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=/var/log/migration_tool.log

# ========================================
# 验证配置
# ========================================

# 验证容差
VALIDATION_TOLERANCE=0.001

# 验证级别：basic, standard, comprehensive
VALIDATION_LEVEL=standard

# ========================================
# 迁移配置
# ========================================

# 默认迁移策略
DEFAULT_MIGRATION_STRATEGY=full_copy

# 大表阈值（行数）
LARGE_TABLE_THRESHOLD=1000000

# 启用逻辑复制
ENABLE_LOGICAL_REPLICATION=true

# ========================================
# 安全配置
# ========================================

# 启用SSL连接
ENABLE_SSL=true

# SSL证书路径
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem